{
  "name": "@skipq/customer-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .expo dist .turbo *.tsbuildinfo",
    "eas:build:dev:android": "eas build --profile development --platform android",
    "eas:build:dev:ios": "eas build --profile development --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:init": "eas init"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@skipq/algorithm": "workspace:*",
    "@skipq/api-client": "workspace:*",
    "@skipq/shared-types": "workspace:*",
    "expo": "~52.0.20",
    "expo-build-properties": "~0.13.2",
    "expo-constants": "~17.0.3",
    "expo-dev-client": "~5.0.20",
    "expo-font": "~13.0.3",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.3",
    "expo-location": "~18.0.10",
    "expo-notifications": "~0.29.11",
    "expo-router": "~4.0.14",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.2",
    "onesignal-expo-plugin": "2.0.4",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-onesignal": "5.2.10",
    "react-native-razorpay": "2.3.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-url-polyfill": "^2.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "^5.6.3"
  }
}
