{
  "expo": {
    "name": "SkipQ",
    "slug": "skipq",
    "scheme": "skipq",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.skipq.app"
    },
    "android": {
      "package": "in.skipq.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF5454"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "oneSignalAppId": "68bf2ff6-ac94-45f3-bec5-2b9863b5b539"
    }
  }
}
