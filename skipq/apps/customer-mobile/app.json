{
  "expo": {
    "name": "SkipQ",
    "slug": "skipq",
    "scheme": "skipq",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.skipq.app"
    },
    "android": {
      "package": "in.skipq.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF5454"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SkipQ uses your location to show salons near you and sort the list by distance."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "oneSignalAppId": "68bf2ff6-ac94-45f3-bec5-2b9863b5b539",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8c87d7fb-1b3c-4073-a283-e3e071fd5818"
      }
    },
    "owner": "jaziljazz"
  }
}
